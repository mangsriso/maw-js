{
  "name": "maw",
  "version": "1.1.0",
  "type": "module",
  "bin": {
    "maw": "./src/cli.ts"
  },
  "scripts": {
    "build:office": "cd office && bunx vite build",
    "dev:office": "cd office && bunx vite",
    "deploy": "bun install && bun run build:office && pm2 restart maw"
  },
  "description": "maw.js — Multi-Agent Workflow in Bun/TS. Remote tmux orchestra control. CLI + Web UI.",
  "dependencies": {
    "hono": "^4.12.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.2.1",
    "vite": "^6.0.0"
  }
}
